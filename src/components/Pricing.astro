---
const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 6h6l-5 4 2 6-5-4-5 4 2-6-5-4h6z" fill="rgba(37,99,235,0.15)" stroke="#3B82F6" stroke-width="1.4" stroke-linejoin="round"/></svg>`,
    text: 'Vacantes ilimitadas',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="#10B981" stroke-width="1.4"/><path d="M7 10l2 2 4-4" stroke="#10B981" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    text: '150 análisis de CV con IA GPT-4o',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="3" y="5" width="14" height="11" rx="2.5" stroke="#10B981" stroke-width="1.4"/><path d="M7 10l2 2 4-4" stroke="#10B981" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    text: 'Detección de habilidades ✅ / ❌',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="2" y="3" width="16" height="14" rx="2.5" stroke="#3B82F6" stroke-width="1.4"/><path d="M6 8h8M6 11h5" stroke="#3B82F6" stroke-width="1.4" stroke-linecap="round"/><path d="M13 14l2-2-2-2" stroke="#3B82F6" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    text: 'Exportación a Excel con ranking',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="9" cy="8" r="4" stroke="#10B981" stroke-width="1.4"/><path d="M3 18c0-3.3 2.7-6 6-6" stroke="#10B981" stroke-width="1.4" stroke-linecap="round"/><path d="M14 12l1.5 1.5L18 11" stroke="#10B981" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    text: 'Verificación de experiencia e idiomas',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="4" y="2" width="12" height="16" rx="2.5" stroke="#3B82F6" stroke-width="1.4"/><path d="M7 7h6M7 10h4" stroke="#3B82F6" stroke-width="1.4" stroke-linecap="round"/><circle cx="14" cy="15" r="3.5" fill="#0A0A0F" stroke="#10B981" stroke-width="1.3"/><path d="M12.8 15.2l1 1 1.5-1.7" stroke="#10B981" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    text: 'Detección de legibilidad ATS del CV',
  },
];
---

<section id="precios">
  <div class="container">

    <!-- Header -->
    <div class="section-header">
      <span class="section-label reveal">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M6 1L7.5 4.5L11 5L8.5 7.5L9 11L6 9.5L3 11L3.5 7.5L1 5L4.5 4.5L6 1Z" fill="currentColor"/>
        </svg>
        Precio
      </span>
      <h2 class="section-title reveal stagger-1">Simple. Sin sorpresas.</h2>
      <p class="section-desc reveal stagger-2">
        Un solo plan con todo incluido. Sin límites de vacantes, sin funciones bloqueadas.
      </p>
    </div>

    <!-- Pricing card — centered, wide -->
    <div class="pricing-wrap reveal stagger-2">
      <div class="pricing-card">

        <!-- Glow border -->
        <div class="card-glow"></div>

        <!-- Left: plan info + price -->
        <div class="card-left">
          <div class="plan-badge">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M7 1L8.6 5.2H13L9.4 7.6L10.8 12L7 9.8L3.2 12L4.6 7.6L1 5.2H5.4L7 1Z" fill="rgba(37,99,235,0.3)" stroke="#3B82F6" stroke-width="1.2" stroke-linejoin="round"/>
            </svg>
            Plan Pro
          </div>

          <div class="plan-tagline">Todo lo que necesitas para reclutar con IA</div>

          <div class="plan-price-block">
            <div class="price-row">
              <span class="price-currency">MXN</span>
              <span class="price-amount">$999</span>
            </div>
            <span class="price-period">por mes · sin contrato</span>
          </div>

          <a href="#cta" class="btn-primary plan-cta">
            Solicitar acceso gratis
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M3.75 9H14.25M14.25 9L10.5 5.25M14.25 9L10.5 12.75" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

          <div class="plan-notes">
            <div class="plan-note">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="#10B981" stroke-width="1.1"/><path d="M5 7l1.5 1.5 2.5-2.5" stroke="#10B981" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Sin tarjeta de crédito
            </div>
            <div class="plan-note">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="#10B981" stroke-width="1.1"/><path d="M5 7l1.5 1.5 2.5-2.5" stroke="#10B981" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Cancela cuando quieras
            </div>
            <div class="plan-note">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="#10B981" stroke-width="1.1"/><path d="M5 7l1.5 1.5 2.5-2.5" stroke="#10B981" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Activa en menos de 5 minutos
            </div>
          </div>
        </div>

        <!-- Divider -->
        <div class="card-divider"></div>

        <!-- Right: features list -->
        <div class="card-right">
          <div class="features-label">Qué incluye el plan Pro</div>
          <ul class="features-list">
            {features.map((f) => (
              <li class="feature-item">
                <div class="feature-icon" set:html={f.icon}></div>
                <span class="feature-text">{f.text}</span>
              </li>
            ))}
          </ul>

          <!-- GPT badge -->
          <div class="gpt-badge">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="6.5" stroke="#2563EB" stroke-width="1.1"/>
              <path d="M5.5 8.5L7 10l3.5-4" stroke="#10B981" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Análisis impulsado por <strong>GPT-4o</strong> — el modelo más avanzado de OpenAI
          </div>
        </div>

      </div>
    </div>

    <!-- Trust strip -->
    <div class="trust-strip reveal">
      <div class="trust-item">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <rect x="2" y="5" width="12" height="9" rx="2" stroke="#2563EB" stroke-width="1.2"/>
          <path d="M5 5V4a3 3 0 016 0v1" stroke="#2563EB" stroke-width="1.2"/>
          <circle cx="8" cy="10" r="1.5" fill="#2563EB"/>
        </svg>
        <span>Datos cifrados con TLS</span>
      </div>
      <div class="trust-sep">·</div>
      <div class="trust-item">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <circle cx="8" cy="8" r="6" stroke="#10B981" stroke-width="1.2"/>
          <path d="M5.5 8.5l2 2 3.5-3.5" stroke="#10B981" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Soporte en horario México</span>
      </div>
      <div class="trust-sep">·</div>
      <div class="trust-item">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <circle cx="8" cy="8" r="6" stroke="#F59E0B" stroke-width="1.2"/>
          <path d="M8 5v3.5l2 1.5" stroke="#F59E0B" stroke-width="1.3" stroke-linecap="round"/>
        </svg>
        <span>Sin contrato ni permanencia</span>
      </div>
    </div>

  </div>
</section>

<style>
  #precios {
    padding: 140px 0;
    background: var(--bg-2);
    position: relative;
  }

  #precios::before,
  #precios::after {
    content: '';
    position: absolute;
    left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }

  #precios::before { top: 0; }
  #precios::after  { bottom: 0; }

  /* Header */
  .section-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    margin-bottom: 72px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 800;
    letter-spacing: -0.035em;
    color: var(--text-primary);
    line-height: 1.1;
  }

  .section-desc {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 440px;
    line-height: 1.75;
  }

  /* Card wrapper */
  .pricing-wrap {
    max-width: 900px;
    margin: 0 auto 56px;
  }

  .pricing-card {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(37,99,235,0.3);
    border-radius: 28px;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(37,99,235,0.1),
      0 40px 100px rgba(37,99,235,0.12),
      0 0 80px rgba(16,185,129,0.05);
  }

  /* Animated top glow line */
  .card-glow {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--blue) 0%, var(--emerald) 100%);
    border-radius: 28px 28px 0 0;
  }

  /* Left column */
  .card-left {
    padding: 52px 48px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .plan-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--blue-light);
    background: rgba(37,99,235,0.1);
    border: 1px solid rgba(37,99,235,0.25);
    padding: 7px 16px;
    border-radius: 100px;
    width: fit-content;
  }

  .plan-tagline {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 260px;
  }

  .plan-price-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .price-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .price-currency {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    align-self: center;
  }

  .price-amount {
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 1;
    background: linear-gradient(135deg, #fff 0%, rgba(255,255,255,0.75) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .price-period {
    font-size: 15px;
    color: var(--text-muted);
    margin-top: 2px;
  }

  .plan-cta {
    font-size: 16px;
    padding: 16px 28px;
    border-radius: 14px;
    justify-content: center;
    text-decoration: none;
    width: 100%;
    box-sizing: border-box;
  }

  .plan-notes {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .plan-note {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
  }

  /* Vertical divider */
  .card-divider {
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(255,255,255,0.1) 20%, rgba(255,255,255,0.1) 80%, transparent);
    margin: 40px 0;
  }

  /* Right column */
  .card-right {
    padding: 52px 48px;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .features-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .features-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
    flex: 1;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .feature-icon {
    width: 40px;
    height: 40px;
    border-radius: 11px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: border-color 0.2s, background 0.2s;
  }

  .feature-item:hover .feature-icon {
    background: rgba(37,99,235,0.08);
    border-color: rgba(37,99,235,0.2);
  }

  .feature-text {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.4;
    transition: color 0.2s;
  }

  .feature-item:hover .feature-text {
    color: var(--text-primary);
  }

  /* GPT badge */
  .gpt-badge {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 13px;
    color: var(--text-muted);
    background: rgba(37,99,235,0.06);
    border: 1px solid rgba(37,99,235,0.18);
    padding: 12px 16px;
    border-radius: 12px;
    line-height: 1.5;
  }

  .gpt-badge svg { flex-shrink: 0; }
  .gpt-badge strong { color: var(--text-primary); font-weight: 600; }

  /* Trust strip */
  .trust-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--text-muted);
  }

  .trust-sep {
    color: var(--border);
    font-size: 18px;
    line-height: 1;
  }

  /* Responsive */
  @media (max-width: 800px) {
    .pricing-card {
      grid-template-columns: 1fr;
    }

    .card-left {
      padding: 40px 32px 32px;
      gap: 24px;
    }

    .card-divider {
      width: auto;
      height: 1px;
      margin: 0 32px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1) 20%, rgba(255,255,255,0.1) 80%, transparent);
    }

    .card-right {
      padding: 32px 32px 40px;
      gap: 24px;
    }

    .price-amount { font-size: 56px; }
    .plan-tagline { max-width: 100%; }
  }

  @media (max-width: 560px) {
    #precios { padding: 96px 0; }
    .section-header { gap: 16px; margin-bottom: 48px; }
    .card-left, .card-right { padding: 28px 24px; }
    .card-divider { margin: 0 24px; }
    .features-list { gap: 16px; }
    .trust-strip { gap: 16px; }
    .trust-sep { display: none; }
    .trust-strip { flex-direction: column; align-items: flex-start; }
  }
</style>
