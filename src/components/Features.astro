---
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
      <circle cx="12" cy="12" r="9" stroke="#2563EB" stroke-width="1.5"/>
      <path d="M12 7v5l3 3" stroke="#10B981" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="12" cy="12" r="2" fill="#2563EB" opacity="0.3"/>
    </svg>`,
    color: 'blue',
    tag: 'Evaluación',
    title: 'Score de compatibilidad 0–100%',
    description: 'Cada CV recibe un porcentaje de compatibilidad calculado por GPT-4o comparando el perfil del candidato contra los requisitos exactos de tu vacante.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
      <path d="M5 17L8 9l4 8 3-5 4 5" stroke="#10B981" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M3 20h18" stroke="#10B981" stroke-width="1.5" stroke-linecap="round"/>
      <circle cx="8" cy="9" r="1.5" fill="#10B981"/>
      <circle cx="12" cy="17" r="1.5" fill="#10B981"/>
      <circle cx="15" cy="12" r="1.5" fill="#10B981"/>
      <circle cx="19" cy="17" r="1.5" fill="#10B981"/>
    </svg>`,
    color: 'emerald',
    tag: 'Ranking',
    title: 'Ranking automático de candidatos',
    description: 'Todos los postulantes se ordenan automáticamente del más al menos compatible. Ve al instante quiénes son tus top 3 sin revisar nada manualmente.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
      <rect x="3" y="6" width="18" height="13" rx="3" stroke="#2563EB" stroke-width="1.5"/>
      <path d="M8 11l2.5 2.5L16 8" stroke="#10B981" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M8 5V3M12 5V3M16 5V3" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
    </svg>`,
    color: 'blue',
    tag: 'Habilidades',
    title: 'Detección de habilidades encontradas vs faltantes',
    description: 'La IA identifica qué skills del perfil requerido están presentes en el CV y cuáles faltan, con un desglose claro para cada candidato.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
      <circle cx="12" cy="8" r="4" stroke="#10B981" stroke-width="1.5"/>
      <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="#10B981" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M16 5l1.5 1.5L20 4" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
    color: 'emerald',
    tag: 'Verificación',
    title: 'Verificación de experiencia, idiomas y perfil',
    description: 'Detecta automáticamente los años de experiencia, los idiomas declarados y si el candidato cumple los criterios mínimos que definiste al crear la vacante.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
      <rect x="4" y="3" width="16" height="18" rx="3" stroke="#2563EB" stroke-width="1.5"/>
      <path d="M8 8h8M8 12h6M8 16h4" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
      <circle cx="18" cy="18" r="4" fill="#0A0A0F" stroke="#10B981" stroke-width="1.5"/>
      <path d="M16.5 18.5l1 1 2-2" stroke="#10B981" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
    color: 'blue',
    tag: 'Compatibilidad ATS',
    title: 'Detección de legibilidad ATS del CV',
    description: 'Verifica si el CV del candidato puede ser leído por sistemas ATS estándar. Detecta PDFs escaneados, tablas problemáticas o texto no extraíble.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
      <path d="M4 6h16M4 10h12M4 14h8" stroke="#10B981" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M14 17l2.5 2.5L21 14" stroke="#10B981" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      <rect x="2" y="3" width="20" height="18" rx="3" stroke="#2563EB" stroke-width="1.5" opacity="0.4"/>
    </svg>`,
    color: 'emerald',
    tag: 'Exportación',
    title: 'Exportación a Excel + notificaciones por email',
    description: 'Descarga todos los resultados en un archivo Excel con rankings, scores y análisis. Recibe una notificación por email cada vez que llegue un nuevo candidato.',
  },
];
---

<section id="funciones">
  <div class="container">
    <div class="section-header">
      <span class="section-label reveal">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M6 1L7.5 4.5L11 5L8.5 7.5L9 11L6 9.5L3 11L3.5 7.5L1 5L4.5 4.5L6 1Z" fill="currentColor"/>
        </svg>
        Funcionalidades
      </span>
      <h2 class="section-title reveal stagger-1">Lo que hace la IA por ti</h2>
      <p class="section-desc reveal stagger-2">
        GPT-4o analiza cada CV en segundos y entrega un reporte completo. Tú solo revisas el ranking.
      </p>
    </div>

    <div class="features-grid">
      {features.map((f, i) => (
        <div class={`feature-card glass-card reveal stagger-${(i % 3) + 1}`}>
          <div class="feature-top">
            <div class={`feature-icon-wrap color-${f.color}`} set:html={f.icon}></div>
            <span class={`feature-tag tag-${f.color}`}>{f.tag}</span>
          </div>
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.description}</p>
        </div>
      ))}
    </div>

    <!-- AI highlight bar -->
    <div class="ai-bar reveal">
      <div class="ai-bar-icon">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M10 2a8 8 0 100 16A8 8 0 0010 2z" fill="rgba(37,99,235,0.15)" stroke="#2563EB" stroke-width="1.2"/>
          <path d="M7 10.5l2 2 4-4" stroke="#10B981" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <p class="ai-bar-text">
        Todos los análisis son realizados por <strong>GPT-4o</strong> — el modelo más avanzado de OpenAI.
        El resultado es preciso, contextual y actualizado con cada nueva postulación.
      </p>
      <div class="ai-bar-dots">
        <span class="ai-dot"></span>
        <span class="ai-dot" style="animation-delay:0.3s"></span>
        <span class="ai-dot" style="animation-delay:0.6s"></span>
      </div>
    </div>
  </div>
</section>

<style>
  #funciones {
    padding: 120px 0;
    background: var(--bg-2);
    position: relative;
  }

  #funciones::before,
  #funciones::after {
    content: '';
    position: absolute;
    left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }

  #funciones::before { top: 0; }
  #funciones::after  { bottom: 0; }

  .section-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    margin-bottom: 64px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  .section-desc {
    font-size: 17px;
    color: var(--text-secondary);
    max-width: 480px;
    line-height: 1.7;
  }

  /* Grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 40px;
  }

  .feature-card {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    overflow: hidden;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .feature-card:hover::before { opacity: 1; }

  .feature-card:nth-child(odd)::before {
    background: linear-gradient(90deg, var(--blue), transparent);
  }

  .feature-card:nth-child(even)::before {
    background: linear-gradient(90deg, var(--emerald), transparent);
  }

  .feature-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .feature-icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .feature-icon-wrap.color-blue {
    background: rgba(37,99,235,0.1);
    border: 1px solid rgba(37,99,235,0.2);
  }

  .feature-icon-wrap.color-emerald {
    background: var(--emerald-glow);
    border: 1px solid rgba(16,185,129,0.2);
  }

  .feature-tag {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 6px;
  }

  .feature-tag.tag-blue {
    color: var(--blue-light);
    background: rgba(37,99,235,0.1);
    border: 1px solid rgba(37,99,235,0.2);
  }

  .feature-tag.tag-emerald {
    color: var(--emerald-light);
    background: var(--emerald-glow);
    border: 1px solid rgba(16,185,129,0.2);
  }

  .feature-title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .feature-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* AI bar */
  .ai-bar {
    display: flex;
    align-items: center;
    gap: 16px;
    background: rgba(37,99,235,0.06);
    border: 1px solid rgba(37,99,235,0.2);
    border-radius: 14px;
    padding: 20px 24px;
  }

  .ai-bar-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(37,99,235,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-bar-text {
    flex: 1;
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .ai-bar-text strong { color: var(--text-primary); }

  .ai-bar-dots {
    display: flex;
    gap: 5px;
    flex-shrink: 0;
  }

  .ai-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--blue);
    opacity: 0.4;
    animation: blink 1.5s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  @media (max-width: 900px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .features-grid { grid-template-columns: 1fr; }
    #funciones { padding: 80px 0; }
    .ai-bar { flex-direction: column; text-align: center; }
    .ai-bar-dots { justify-content: center; }
    .feature-card { padding: 20px; }
    .section-header { margin-bottom: 40px; }
  }
</style>
