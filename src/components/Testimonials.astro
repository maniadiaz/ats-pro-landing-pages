---
const testimonials = [
  {
    initials: 'LM',
    name: 'Lorena Medina',
    title: 'Directora de Recursos Humanos',
    company: 'Grupo Inmobiliario Zentri',
    avatarColor: 'from-blue-700 to-indigo-900',
    bg: '#1e3a8a',
    quote: 'Antes tardábamos dos semanas en revisar 80 CVs para una sola vacante. Con ATS Pro, en dos horas ya teníamos el ranking completo y sabíamos exactamente a quién llamar. El score de compatibilidad es sorprendentemente preciso.',
    metric: '87%',
    metricLabel: 'menos tiempo en filtros iniciales',
  },
  {
    initials: 'RV',
    name: 'Ricardo Vargas',
    title: 'CEO',
    company: 'Novatek Soluciones',
    avatarColor: 'from-emerald-700 to-teal-900',
    bg: '#065f46',
    quote: 'Somos una empresa de tecnología y el reclutamiento técnico siempre fue un cuello de botella. ATS Pro detecta exactamente qué habilidades tiene cada candidato y cuáles le faltan. Nuestros tech leads ahora solo entrevistan a los que ya pasaron el filtro de IA.',
    metric: '3x',
    metricLabel: 'más candidatos procesados por mes',
  },
  {
    initials: 'AP',
    name: 'Andrea Pacheco',
    title: 'Gerente de Talento',
    company: 'Red de Clínicas MediSalud',
    avatarColor: 'from-violet-700 to-purple-900',
    bg: '#4c1d95',
    quote: 'Lo que más me convenció fue el link público. Lo compartimos por WhatsApp a grupos de interés y en dos días teníamos 40 postulaciones analizadas y rankeadas. Nunca habíamos cubierto una plaza de enfermería en menos de una semana.',
    metric: '6 días',
    metricLabel: 'para cubrir una vacante urgente',
  },
];
---

<section id="testimonios">
  <div class="container">
    <div class="section-header">
      <span class="section-label reveal">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M2 4h8M2 7h6M2 10h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
        </svg>
        Testimonios
      </span>
      <h2 class="section-title reveal stagger-1">Lo que dicen quienes ya reclutan con IA</h2>
      <p class="section-desc reveal stagger-2">
        Empresas mexicanas que transformaron su proceso de reclutamiento con ATS Pro.
      </p>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <div class={`testimonial-card glass-card reveal stagger-${i + 1}`}>
          <!-- Quote icon -->
          <div class="quote-icon">
            <svg width="32" height="24" viewBox="0 0 32 24" fill="none">
              <path d="M8 0C3.6 0 0 3.6 0 8c0 4.4 3.6 8 8 8 .4 0 .8 0 1.2-.1L4 24h4l6-9.6C15.2 12.3 16 10.2 16 8c0-4.4-3.6-8-8-8zm16 0c-4.4 0-8 3.6-8 8 0 4.4 3.6 8 8 8 .4 0 .8 0 1.2-.1L20 24h4l6-9.6C31.2 12.3 32 10.2 32 8c0-4.4-3.6-8-8-8z" fill="rgba(37,99,235,0.15)"/>
            </svg>
          </div>

          <!-- Metric highlight -->
          <div class="testimonial-metric">
            <span class="metric-value">{t.metric}</span>
            <span class="metric-label">{t.metricLabel}</span>
          </div>

          <!-- Quote text -->
          <blockquote class="testimonial-quote">
            "{t.quote}"
          </blockquote>

          <!-- Author -->
          <div class="testimonial-author">
            <div class="author-avatar" style={`background: ${t.bg}`}>
              {t.initials}
            </div>
            <div class="author-info">
              <span class="author-name">{t.name}</span>
              <span class="author-role">{t.title} · <strong>{t.company}</strong></span>
            </div>
            <!-- Stars -->
            <div class="author-stars">
              {Array.from({length: 5}).map(() => (
                <svg width="14" height="14" viewBox="0 0 14 14" fill="#F59E0B">
                  <path d="M7 1L8.6 5H13L9.5 7.5L10.8 12L7 9.8L3.2 12L4.5 7.5L1 5H5.4L7 1Z"/>
                </svg>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Social proof bar -->
    <div class="social-proof reveal">
      <div class="proof-stat">
        <span class="proof-num">+240</span>
        <span class="proof-label">empresas en México</span>
      </div>
      <div class="proof-divider"></div>
      <div class="proof-stat">
        <span class="proof-num">+18,000</span>
        <span class="proof-label">CVs analizados por IA</span>
      </div>
      <div class="proof-divider"></div>
      <div class="proof-stat">
        <span class="proof-num">4.9 / 5</span>
        <span class="proof-label">calificación promedio</span>
      </div>
      <div class="proof-divider"></div>
      <div class="proof-stat">
        <span class="proof-num">< 30 seg</span>
        <span class="proof-label">por análisis de CV</span>
      </div>
    </div>
  </div>
</section>

<style>
  #testimonios {
    padding: 120px 0;
    position: relative;
  }

  .section-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    margin-bottom: 60px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(26px, 3.5vw, 40px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    max-width: 560px;
  }

  .section-desc {
    font-size: 17px;
    color: var(--text-secondary);
    max-width: 440px;
    line-height: 1.7;
  }

  /* Grid */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 48px;
  }

  .testimonial-card {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .quote-icon { opacity: 0.6; }

  /* Metric */
  .testimonial-metric {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .metric-value {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, var(--blue-light), var(--emerald-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .metric-label {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.4;
  }

  /* Quote */
  .testimonial-quote {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    font-style: italic;
    flex: 1;
    border-left: 2px solid rgba(37,99,235,0.3);
    padding-left: 16px;
  }

  /* Author */
  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 4px;
    border-top: 1px solid var(--border);
  }

  .author-avatar {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    color: rgba(255,255,255,0.9);
    flex-shrink: 0;
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .author-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .author-role {
    font-size: 12px;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .author-role strong {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .author-stars {
    display: flex;
    gap: 1px;
    flex-shrink: 0;
  }

  /* Social proof */
  .social-proof {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 28px 40px;
  }

  .proof-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-align: center;
  }

  .proof-num {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--text-primary);
  }

  .proof-label {
    font-size: 12px;
    color: var(--text-muted);
  }

  .proof-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }

  @media (max-width: 900px) {
    .testimonials-grid { grid-template-columns: 1fr; max-width: 560px; margin: 0 auto 48px; }
    .social-proof { gap: 24px; padding: 24px; }
  }

  @media (max-width: 600px) {
    #testimonios { padding: 80px 0; }
    .social-proof {
      flex-wrap: wrap;
      gap: 20px;
    }
    .proof-divider { display: none; }
  }
</style>
