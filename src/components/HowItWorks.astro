---
const steps = [
  {
    number: '01',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <rect x="4" y="4" width="20" height="20" rx="5" stroke="#2563EB" stroke-width="1.5"/>
      <path d="M9 10h10M9 14h7M9 18h5" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round"/>
      <circle cx="20" cy="20" r="4" fill="#0A0A0F" stroke="#10B981" stroke-width="1.5"/>
      <path d="M18.5 20l1 1 2-2" stroke="#10B981" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
    title: 'Crea tu vacante en minutos',
    description: 'Define el puesto, las habilidades requeridas, nivel de experiencia e idiomas. La IA entiende el perfil que buscas y lo usa como referencia para evaluar cada CV.',
    detail: 'Sin formatos complicados. Sin hojas de Excel.',
  },
  {
    number: '02',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <path d="M14 4a10 10 0 100 20A10 10 0 0014 4z" stroke="#2563EB" stroke-width="1.5"/>
      <path d="M14 4c-2.5 3-4 6-4 10s1.5 7 4 10" stroke="#2563EB" stroke-width="1.5"/>
      <path d="M14 4c2.5 3 4 6 4 10s-1.5 7-4 10" stroke="#2563EB" stroke-width="1.5"/>
      <path d="M4 14h20" stroke="#2563EB" stroke-width="1.5"/>
      <circle cx="14" cy="14" r="2.5" fill="#10B981"/>
    </svg>`,
    title: 'Comparte el link público',
    description: 'Obtén un link único para tu vacante y compártelo donde quieras: WhatsApp, LinkedIn, Instagram, email, o incrústalo en tu sitio web.',
    detail: 'Un solo link. Todos los canales.',
  },
  {
    number: '03',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <path d="M8 20V12a6 6 0 0112 0v8" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round"/>
      <rect x="4" y="18" width="20" height="6" rx="3" stroke="#2563EB" stroke-width="1.5"/>
      <path d="M14 10v4M12 12h4" stroke="#10B981" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
    title: 'Los candidatos suben su CV',
    description: 'Los postulantes acceden al link, completan un formulario breve y suben su CV en PDF. Todo desde su celular o computadora, sin crear cuenta.',
    detail: 'Experiencia simple para el candidato.',
  },
  {
    number: '04',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <circle cx="14" cy="14" r="9" stroke="#2563EB" stroke-width="1.5"/>
      <path d="M10 14l3 3 5-6" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M14 5V7M14 21v2M5 14H7M21 14h2" stroke="#2563EB" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
    </svg>`,
    title: 'La IA analiza y rankea automáticamente',
    description: 'En segundos recibes un ranking completo: score de compatibilidad, habilidades encontradas vs faltantes, verificación de experiencia e idiomas, y notificación por email.',
    detail: 'Resultados instantáneos. Sin leer un solo CV.',
  },
];
---

<section id="como-funciona">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M6 1L7.5 4.5L11 5L8.5 7.5L9 11L6 9.5L3 11L3.5 7.5L1 5L4.5 4.5L6 1Z" fill="currentColor"/>
        </svg>
        Proceso simple
      </span>
      <h2 class="section-title reveal stagger-1">Cómo funciona ATS Pro</h2>
      <p class="section-desc reveal stagger-2">
        Cuatro pasos para transformar tu proceso de reclutamiento. De la vacante al candidato ideal, todo automatizado.
      </p>
    </div>

    <!-- Steps connector line -->
    <div class="steps-wrapper">
      <div class="connector-line"></div>

      {steps.map((step, i) => (
        <div class={`step reveal stagger-${i + 1}`}>
          <div class="step-number-wrap">
            <div class="step-circle">
              <span class="step-num">{step.number}</span>
            </div>
            <div class="step-icon-wrap" set:html={step.icon}></div>
          </div>

          <div class="step-content">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.description}</p>
            <span class="step-detail">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M2 6h8M8 4l2 2-2 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {step.detail}
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom highlight -->
    <div class="hiw-cta reveal">
      <div class="hiw-cta-inner">
        <div class="hiw-cta-icon">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <path d="M11 2L13.2 7.8L19 8.2L14.8 12.4L16.2 18L11 15L5.8 18L7.2 12.4L3 8.2L8.8 7.8L11 2Z" fill="#10B981" opacity="0.2" stroke="#10B981" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="hiw-cta-text">
          <span class="hiw-cta-title">Configura tu primera vacante en menos de 5 minutos</span>
          <span class="hiw-cta-sub">Sin tarjeta de crédito. Sin instalaciones.</span>
        </div>
        <a href="#cta" class="btn-primary hiw-btn">
          Comenzar gratis
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M10 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  #como-funciona {
    padding: 120px 0;
    position: relative;
  }

  #como-funciona::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }

  .section-header {
    text-align: center;
    margin-bottom: 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  .section-desc {
    font-size: 17px;
    color: var(--text-secondary);
    max-width: 520px;
    line-height: 1.7;
    text-align: center;
  }

  /* Steps */
  .steps-wrapper {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    margin-bottom: 64px;
  }

  .connector-line {
    position: absolute;
    top: 48px;
    left: calc(12.5% + 20px);
    right: calc(12.5% + 20px);
    height: 1px;
    background: linear-gradient(90deg, var(--blue) 0%, var(--emerald) 100%);
    opacity: 0.3;
    pointer-events: none;
  }

  .connector-line::before,
  .connector-line::after {
    content: '';
    position: absolute;
    top: -2px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--blue);
  }

  .connector-line::before { left: 0; }
  .connector-line::after  { right: 0; background: var(--emerald); }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
  }

  .step-number-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .step-circle {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .step:hover .step-circle {
    border-color: rgba(37,99,235,0.4);
    box-shadow: 0 0 32px rgba(37,99,235,0.12);
  }

  .step-num {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: rgba(255,255,255,0.07);
    position: absolute;
    top: 12px;
    right: 14px;
    line-height: 1;
  }

  .step-icon-wrap {
    position: relative;
    z-index: 1;
  }

  .step-content {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .step-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .step-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .step-detail {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: var(--emerald);
    margin-top: 4px;
  }

  /* Bottom CTA banner */
  .hiw-cta {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2px;
    background: linear-gradient(135deg, rgba(37,99,235,0.08), rgba(16,185,129,0.08));
  }

  .hiw-cta-inner {
    display: flex;
    align-items: center;
    gap: 20px;
    background: rgba(10,10,15,0.85);
    border-radius: 18px;
    padding: 24px 28px;
  }

  .hiw-cta-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--emerald-glow);
    border: 1px solid rgba(16,185,129,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hiw-cta-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .hiw-cta-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .hiw-cta-sub {
    font-size: 14px;
    color: var(--text-secondary);
  }

  .hiw-btn {
    flex-shrink: 0;
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .steps-wrapper {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
    }
    .connector-line { display: none; }
    .hiw-cta-inner { flex-direction: column; text-align: center; }
  }

  @media (max-width: 560px) {
    .steps-wrapper { grid-template-columns: 1fr; gap: 32px; }
    #como-funciona { padding: 80px 0; }
    .section-header { margin-bottom: 48px; }
    .hiw-cta-inner { gap: 16px; }
    .hiw-cta-title { font-size: 16px; }
    .hiw-btn { width: 100%; justify-content: center; }
  }
</style>
