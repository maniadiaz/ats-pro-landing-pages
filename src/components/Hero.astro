---
const candidates = [
  { name: 'Alejandra Moreno R.', role: 'Desarrollador Frontend', score: 94, skills: ['React', 'TypeScript', 'CSS'], exp: '5 años', rank: 1 },
  { name: 'Carlos Ibáñez V.', role: 'Desarrollador Frontend', score: 87, skills: ['Vue', 'JavaScript', 'Tailwind'], exp: '4 años', rank: 2 },
  { name: 'Fernanda López G.', role: 'Desarrollador Frontend', score: 72, skills: ['React', 'HTML/CSS'], exp: '3 años', rank: 3 },
  { name: 'Miguel Ángel Soto', role: 'Desarrollador Frontend', score: 61, skills: ['JavaScript', 'jQuery'], exp: '2 años', rank: 4 },
  { name: 'Daniela Ruiz P.', role: 'Desarrollador Frontend', score: 38, skills: ['HTML', 'Bootstrap'], exp: '1 año', rank: 5 },
];

function scoreClass(score: number) {
  if (score >= 80) return 'high';
  if (score >= 50) return 'mid';
  return 'low';
}

function scoreColor(score: number) {
  if (score >= 80) return '#10B981';
  if (score >= 50) return '#F59E0B';
  return '#EF4444';
}
---

<section id="hero">
  <!-- Animated background -->
  <div class="hero-bg">
    <div class="grid-overlay"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="noise"></div>
  </div>

  <div class="container">
    <div class="hero-content">
      <!-- Badge -->
      <div class="hero-badge reveal">
        <span class="badge-dot"></span>
        <span>Powered by GPT-4o</span>
        <span class="badge-sep">·</span>
        <span>Análisis instantáneo de CVs</span>
      </div>

      <!-- Headline -->
      <h1 class="hero-headline reveal stagger-1">
        Contrata al mejor candidato.<br />
        <span class="headline-gradient">La IA lee los CVs por ti.</span>
      </h1>

      <!-- Subheadline -->
      <p class="hero-sub reveal stagger-2">
        Crea una vacante, comparte un link público en WhatsApp, LinkedIn o Instagram,
        y deja que la inteligencia artificial analice cada CV, calcule un score de compatibilidad
        y rankee a tus candidatos automáticamente. Sin leer CV por CV.
      </p>

      <!-- CTAs -->
      <div class="hero-ctas reveal stagger-3">
        <a href="#cta" class="btn-primary hero-cta-primary">
          Empieza gratis
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M3.75 9H14.25M14.25 9L10.5 5.25M14.25 9L10.5 12.75" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#demo" class="btn-secondary hero-cta-secondary">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M7.5 6.5L12 9L7.5 11.5V6.5Z" fill="currentColor"/>
          </svg>
          Ver demo
        </a>
      </div>

      <!-- Stats -->
      <div class="hero-stats reveal stagger-4">
        <div class="stat">
          <span class="stat-value">3 min</span>
          <span class="stat-label">para publicar una vacante</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">< 30 seg</span>
          <span class="stat-label">por análisis de CV</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">100%</span>
          <span class="stat-label">automático</span>
        </div>
      </div>
    </div>

    <!-- Dashboard mockup -->
    <div class="hero-mockup reveal stagger-2">
      <div class="mockup-window">
        <!-- Window chrome -->
        <div class="window-bar">
          <div class="window-dots">
            <span class="dot dot-red"></span>
            <span class="dot dot-yellow"></span>
            <span class="dot dot-green"></span>
          </div>
          <div class="window-title">ATS Pro — Vacante: Desarrollador Frontend Senior</div>
          <div class="window-actions">
            <span class="window-pill">5 candidatos</span>
          </div>
        </div>

        <!-- Dashboard content -->
        <div class="dashboard">
          <!-- Top bar -->
          <div class="dash-topbar">
            <div class="dash-search">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="6" cy="6" r="4.5" stroke="#475569" stroke-width="1.2"/><path d="M9.5 9.5L12 12" stroke="#475569" stroke-width="1.2" stroke-linecap="round"/></svg>
              <span>Buscar candidato...</span>
            </div>
            <div class="dash-filters">
              <span class="filter-chip active">Todos</span>
              <span class="filter-chip">Alta compatibilidad</span>
              <span class="filter-chip">Exportar Excel</span>
            </div>
          </div>

          <!-- Table header -->
          <div class="table-head">
            <span class="col-rank">#</span>
            <span class="col-name">Candidato</span>
            <span class="col-score">Score IA</span>
            <span class="col-skills">Habilidades</span>
            <span class="col-exp">Experiencia</span>
            <span class="col-action"></span>
          </div>

          <!-- Candidate rows -->
          {candidates.map((c) => (
            <div class={`candidate-row rank-${c.rank}`}>
              <span class="col-rank">
                {c.rank === 1 && (
                  <span class="rank-badge gold">#{c.rank}</span>
                )}
                {c.rank === 2 && (
                  <span class="rank-badge silver">#{c.rank}</span>
                )}
                {c.rank === 3 && (
                  <span class="rank-badge bronze">#{c.rank}</span>
                )}
                {c.rank > 3 && (
                  <span class="rank-num">#{c.rank}</span>
                )}
              </span>
              <span class="col-name">
                <span class="candidate-avatar" style={`background: linear-gradient(135deg, hsl(${c.rank * 47 + 180}deg 60% 35%), hsl(${c.rank * 47 + 220}deg 70% 25%))`}>
                  {c.name.split(' ').map((n: string) => n[0]).slice(0, 2).join('')}
                </span>
                <span class="candidate-info">
                  <span class="candidate-name">{c.name}</span>
                  <span class="candidate-role">{c.role}</span>
                </span>
              </span>
              <span class="col-score">
                <span class="score-ring" style={`--score-color: ${scoreColor(c.score)}; --score-pct: ${c.score}%`}>
                  <svg viewBox="0 0 36 36" class="score-svg">
                    <circle cx="18" cy="18" r="15" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="3"/>
                    <circle cx="18" cy="18" r="15" fill="none" stroke={scoreColor(c.score)} stroke-width="3"
                      stroke-dasharray={`${c.score * 0.942} 94.2`}
                      stroke-linecap="round"
                      transform="rotate(-90 18 18)"
                      opacity="0.9"/>
                  </svg>
                  <span class={`score-num score-${scoreClass(c.score)}`}>{c.score}%</span>
                </span>
              </span>
              <span class="col-skills">
                {c.skills.map((s: string) => (
                  <span class="skill-tag">{s}</span>
                ))}
              </span>
              <span class="col-exp">
                <span class="exp-badge">{c.exp}</span>
              </span>
              <span class="col-action">
                <button class="action-btn">Ver perfil</button>
              </span>
            </div>
          ))}

          <!-- Bottom bar -->
          <div class="dash-bottom">
            <span class="dash-info">
              <span class="info-dot"></span>
              Actualizado hace 2 minutos · 5 de 5 CVs analizados
            </span>
            <span class="dash-export">
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M6.5 1v7M4 6l2.5 2.5L9 6" stroke="#10B981" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/><path d="M1.5 9.5v1a1 1 0 001 1h9a1 1 0 001-1v-1" stroke="#10B981" stroke-width="1.3" stroke-linecap="round"/></svg>
              Exportar resultados
            </span>
          </div>
        </div>
      </div>

      <!-- Floating notification -->
      <div class="float-notif">
        <div class="notif-icon">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1.5a5.25 5.25 0 100 10.5A5.25 5.25 0 008 1.5z" fill="#10B981" opacity="0.2"/><path d="M5.5 8l2 2 3-3" stroke="#10B981" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="notif-text">
          <span class="notif-title">Nuevo candidato analizado</span>
          <span class="notif-body">Score: 94% — Alta compatibilidad</span>
        </div>
      </div>

      <!-- Floating link pill -->
      <div class="float-link">
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M5.5 7l2-2m0 0a2.5 2.5 0 013.5-3.5l1 1a2.5 2.5 0 010 3.5L11 7M2 10.5l1-1a2.5 2.5 0 013.5 0l1 1" stroke="#3B82F6" stroke-width="1.2" stroke-linecap="round"/></svg>
        <span>atspro.mx/v/frontend-senior-482</span>
      </div>
    </div>
  </div>
</section>

<style>
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 120px 0 80px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 0%, black 40%, transparent 100%);
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .orb-1 {
    width: 600px; height: 600px;
    background: rgba(37, 99, 235, 0.15);
    top: -200px; left: -100px;
    animation: drift 12s ease-in-out infinite alternate;
  }

  .orb-2 {
    width: 400px; height: 400px;
    background: rgba(16, 185, 129, 0.1);
    top: 100px; right: -100px;
    animation: drift 16s ease-in-out infinite alternate-reverse;
  }

  .orb-3 {
    width: 300px; height: 300px;
    background: rgba(37, 99, 235, 0.08);
    bottom: -50px; left: 40%;
    animation: drift 20s ease-in-out infinite alternate;
  }

  @keyframes drift {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(40px, 30px) scale(1.05); }
  }

  .noise {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  .container {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  /* LEFT SIDE */
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    padding: 7px 16px;
    border-radius: 100px;
    width: fit-content;
  }

  .badge-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--emerald);
    box-shadow: 0 0 0 3px rgba(16,185,129,0.2);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(16,185,129,0.2); }
    50% { box-shadow: 0 0 0 6px rgba(16,185,129,0.05); }
  }

  .badge-sep { color: var(--text-muted); }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(36px, 4.5vw, 58px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  .headline-gradient {
    background: linear-gradient(135deg, var(--blue-light) 0%, var(--emerald-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 480px;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hero-cta-primary {
    font-size: 15px;
    padding: 14px 28px;
  }

  .hero-cta-secondary {
    font-size: 15px;
    padding: 14px 24px;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 24px;
    padding-top: 8px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-size: 12px;
    color: var(--text-muted);
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* MOCKUP */
  .hero-mockup {
    position: relative;
  }

  .mockup-window {
    background: rgba(15, 15, 24, 0.8);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.04),
      0 32px 80px rgba(0,0,0,0.5),
      0 0 80px rgba(37, 99, 235, 0.08);
    backdrop-filter: blur(20px);
  }

  .window-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid var(--border);
  }

  .window-dots { display: flex; gap: 6px; }
  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot-red { background: #FF5F56; }
  .dot-yellow { background: #FEBC2E; }
  .dot-green { background: #28C840; }

  .window-title {
    flex: 1;
    font-size: 12px;
    color: var(--text-muted);
    text-align: center;
    font-family: var(--font-body);
  }

  .window-pill {
    font-size: 11px;
    color: var(--emerald);
    background: var(--emerald-glow);
    border: 1px solid rgba(16,185,129,0.2);
    padding: 3px 10px;
    border-radius: 100px;
  }

  .dashboard {
    padding: 0;
  }

  .dash-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    gap: 12px;
  }

  .dash-search {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--text-muted);
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    padding: 7px 12px;
    border-radius: 8px;
    width: 180px;
  }

  .dash-filters {
    display: flex;
    gap: 6px;
  }

  .filter-chip {
    font-size: 11px;
    color: var(--text-muted);
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    padding: 5px 10px;
    border-radius: 6px;
    cursor: pointer;
  }

  .filter-chip.active {
    color: var(--blue-light);
    background: rgba(37,99,235,0.1);
    border-color: rgba(37,99,235,0.3);
  }

  .table-head {
    display: grid;
    grid-template-columns: 44px 1fr 90px 160px 90px 80px;
    gap: 8px;
    padding: 8px 16px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }

  .candidate-row {
    display: grid;
    grid-template-columns: 44px 1fr 90px 160px 90px 80px;
    gap: 8px;
    padding: 10px 16px;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background 0.15s;
  }

  .candidate-row:last-of-type { border-bottom: none; }

  .candidate-row:hover {
    background: rgba(255,255,255,0.03);
  }

  .candidate-row.rank-1 {
    background: rgba(16,185,129,0.04);
  }

  .rank-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 7px;
    border-radius: 6px;
  }

  .rank-badge.gold   { background: rgba(245,158,11,0.15); color: #F59E0B; }
  .rank-badge.silver { background: rgba(148,163,184,0.12); color: #94A3B8; }
  .rank-badge.bronze { background: rgba(180,120,60,0.15); color: #CD7F32; }
  .rank-num { font-size: 12px; color: var(--text-muted); }

  .col-name {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .candidate-avatar {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    color: rgba(255,255,255,0.85);
    flex-shrink: 0;
  }

  .candidate-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .candidate-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .candidate-role {
    font-size: 11px;
    color: var(--text-muted);
  }

  .col-score {
    display: flex;
    justify-content: center;
  }

  .score-ring {
    position: relative;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .score-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .score-num {
    font-size: 10px;
    font-weight: 700;
    z-index: 1;
  }

  .score-high { color: var(--emerald); }
  .score-mid  { color: var(--amber); }
  .score-low  { color: var(--red); }

  .col-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .skill-tag {
    font-size: 10px;
    color: var(--text-secondary);
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--border);
    padding: 2px 7px;
    border-radius: 4px;
    white-space: nowrap;
  }

  .exp-badge {
    font-size: 12px;
    color: var(--text-secondary);
  }

  .action-btn {
    font-size: 11px;
    font-weight: 500;
    color: var(--blue-light);
    background: rgba(37,99,235,0.1);
    border: 1px solid rgba(37,99,235,0.2);
    padding: 5px 10px;
    border-radius: 6px;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.15s;
  }

  .action-btn:hover {
    background: rgba(37,99,235,0.2);
  }

  .dash-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    border-top: 1px solid var(--border);
    background: rgba(255,255,255,0.02);
  }

  .dash-info {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 11px;
    color: var(--text-muted);
  }

  .info-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--emerald);
    animation: pulse 2s infinite;
  }

  .dash-export {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    color: var(--emerald);
    cursor: pointer;
  }

  /* Floating elements */
  .float-notif {
    position: absolute;
    bottom: -20px;
    left: -24px;
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(15,15,24,0.95);
    border: 1px solid rgba(16,185,129,0.3);
    border-radius: 12px;
    padding: 12px 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.04);
    backdrop-filter: blur(20px);
    animation: floatUp 3s ease-in-out infinite alternate;
  }

  @keyframes floatUp {
    from { transform: translateY(0px); }
    to   { transform: translateY(-8px); }
  }

  .notif-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--emerald-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .notif-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .notif-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .notif-body {
    font-size: 11px;
    color: var(--text-secondary);
  }

  .float-link {
    position: absolute;
    top: -16px;
    right: -16px;
    display: flex;
    align-items: center;
    gap: 7px;
    background: rgba(15,15,24,0.95);
    border: 1px solid rgba(37,99,235,0.3);
    border-radius: 100px;
    padding: 8px 14px;
    font-size: 11px;
    color: var(--blue-light);
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    backdrop-filter: blur(20px);
    animation: floatUp 4s ease-in-out infinite alternate-reverse;
  }

  @media (max-width: 1024px) {
    .container {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .hero-content { align-items: center; text-align: center; }
    .hero-sub { margin: 0 auto; }
    .hero-badge { margin: 0 auto; }
    .hero-stats { justify-content: center; }
