---
const candidate = {
  initials: 'CA',
  name: 'Carlos Andrade Villanueva',
  phone: '669•••••••',
  email: 'c.andrade••••@gmail.com',
  score: 85,
  recommendation: 'APTO',
  skills: ['JavaScript', 'TypeScript', 'React.js', 'Node.js', 'Express.js', 'REST APIs', 'Git', 'JWT/Auth', 'Docker', 'PostgreSQL', 'MySQL'],
  missing: ['MongoDB', 'Deploy en VPS o servicios cloud'],
  strengths: [
    'Experiencia en proyectos personales y colaborativos',
    'Conocimientos sólidos en tecnologías requeridas',
    'Proactividad y capacidad para resolver problemas',
  ],
  improvements: [
    'Falta de experiencia con MongoDB',
    'Falta de experiencia en deploy en VPS o servicios cloud',
  ],
  summary: 'Carlos Andrade Villanueva es un candidato apto para la posición de Desarrollador Full Stack Jr. en Nocompila. Posee las habilidades técnicas requeridas y experiencia en proyectos personales que demuestran su capacidad para el rol.',
};
---

<section id="demo">
  <div class="container">
    <div class="section-header">
      <span class="section-label reveal">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M4.5 6l1.5 1.5 2.5-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Demo interactivo
      </span>
      <h2 class="section-title reveal stagger-1">Míralo en acción</h2>
      <p class="section-desc reveal stagger-2">
        Así se ve el flujo real de ATS Pro. Desde crear la vacante hasta el análisis completo de cada candidato.
      </p>
    </div>

    <div class="demo-wrapper reveal stagger-2">

      <!-- Step indicator -->
      <div class="demo-steps">
        <button class="step-btn active" data-tab="vacante">
          <span class="step-num">1</span>
          <span class="step-label">Crear vacante</span>
        </button>
        <div class="step-connector"></div>
        <button class="step-btn" data-tab="link">
          <span class="step-num">2</span>
          <span class="step-label">Link público</span>
        </button>
        <div class="step-connector"></div>
        <button class="step-btn" data-tab="candidatos">
          <span class="step-num">3</span>
          <span class="step-label">Candidatos analizados</span>
        </button>
      </div>

      <!-- Tab panels -->
      <div class="demo-body">

        <!-- ─── TAB 1: Crear vacante ─── -->
        <div class="tab-panel active" id="tab-vacante">
          <div class="tab-header">
            <div>
              <div class="breadcrumb">Vacantes › <strong>Nueva vacante</strong></div>
              <h3 class="tab-title">Nueva vacante</h3>
              <p class="tab-subtitle">Completa los requisitos para que la IA evalúe correctamente a los candidatos</p>
            </div>
            <div class="tab-actions">
              <button class="action-cancel">Cancelar</button>
              <button class="action-create btn-primary" id="btnCrearVacante">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
                Crear vacante
              </button>
            </div>
          </div>

          <div class="form-sections">
            <!-- Información del puesto -->
            <div class="form-section">
              <div class="form-section-title">INFORMACIÓN DEL PUESTO</div>
              <div class="fields-grid-2">
                <div class="mock-field">
                  <span class="mock-placeholder">Título del puesto <span class="req">**</span></span>
                  <span class="mock-value">Desarrollador Full Stack Jr. (Node.js / React)</span>
                </div>
                <div class="mock-field mock-select">
                  <span class="mock-placeholder">Área profesional <span class="req">**</span></span>
                  <span class="mock-value">Tecnología</span>
                  <svg class="select-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3.5 5.5l3.5 3.5 3.5-3.5" stroke="#94A3B8" stroke-width="1.3" stroke-linecap="round"/></svg>
                </div>
                <div class="mock-field">
                  <span class="mock-placeholder">Empresa o proyecto <span class="req">**</span></span>
                  <span class="mock-value">Nocompila</span>
                </div>
                <div class="mock-field">
                  <span class="mock-placeholder">Años de experiencia <span class="req">**</span></span>
                  <span class="mock-value">1</span>
                </div>
              </div>
            </div>

            <!-- Descripción del rol -->
            <div class="form-section">
              <div class="form-section-title">DESCRIPCIÓN DEL ROL</div>
              <div class="mock-field mock-textarea">
                <span class="mock-placeholder">Descripción <span class="req">**</span></span>
                <span class="mock-value textarea-val">Buscamos un Desarrollador Full Stack Jr. con conocimientos en Node.js y React. Trabajarás en proyectos reales con un equipo pequeño y dinámico. Se valora experiencia en APIs REST, bases de datos relacionales y manejo de Git.</span>
                <span class="textarea-hint">Una descripción detallada mejora la precisión del análisis IA</span>
              </div>
            </div>

            <!-- Requisitos -->
            <div class="form-section">
              <div class="form-section-title">REQUISITOS</div>
              <div class="mock-field mock-textarea short">
                <span class="mock-placeholder">Habilidades y conocimientos requeridos <span class="req">**</span></span>
                <span class="mock-value">JavaScript, TypeScript, React.js, Node.js, Express.js, REST APIs, Git, JWT/Auth, Docker, PostgreSQL, MySQL, MongoDB, Deploy en VPS o servicios cloud</span>
                <span class="textarea-hint">Separa cada habilidad con coma. Sé específico para mejores resultados.</span>
              </div>
              <div class="fields-grid-2 lang-row">
                <div class="mock-field mock-select lang-field">
                  <span class="lang-label">Inglés requerido</span>
                  <span class="mock-value">Intermedio</span>
                  <svg class="select-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3.5 5.5l3.5 3.5 3.5-3.5" stroke="#94A3B8" stroke-width="1.3" stroke-linecap="round"/></svg>
                </div>
                <div class="mock-field mock-select lang-field">
                  <span class="lang-label">Español requerido</span>
                  <span class="mock-value">Nativo</span>
                  <svg class="select-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3.5 5.5l3.5 3.5 3.5-3.5" stroke="#94A3B8" stroke-width="1.3" stroke-linecap="round"/></svg>
                </div>
              </div>
              <div class="mock-field mock-textarea short">
                <span class="mock-placeholder">Otros requisitos (opcional)</span>
              </div>
            </div>
          </div>
        </div>

        <!-- ─── TAB 2: Link público + candidatos ─── -->
        <div class="tab-panel" id="tab-link">
          <div class="tab-header">
            <div>
              <div class="breadcrumb">Vacantes › <strong>Desarrollador Full Stack Jr. (Node.js / React)</strong></div>
              <div class="vacancy-title-row">
                <h3 class="tab-title">Desarrollador Full Stack Jr. (Node.js / React)</h3>
                <span class="badge-abierta">Abierta</span>
                <span class="badge-area">Tecnología</span>
              </div>
              <p class="vacancy-meta">Nocompila · Desde 25 may 2026 · Hasta 29 jun 2026</p>
            </div>
          </div>

          <div class="vacancy-toolbar">
            <div class="toolbar-left">
              <div class="toggle-notif">
                <span class="toggle-track on"></span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1.5a4 4 0 014 4v1.5l1 1.5H2l1-1.5V5.5a4 4 0 014-4z" stroke="currentColor" stroke-width="1.2"/><path d="M5.5 11.5a1.5 1.5 0 003 0" stroke="currentColor" stroke-width="1.2"/></svg>
                <span>Notificaciones</span>
              </div>
              <button class="toolbar-btn">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M2 6.5h9M8 3.5l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                Editar
              </button>
              <button class="toolbar-btn danger">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.2"/><path d="M4.5 4.5l4 4M8.5 4.5l-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                Cerrar
              </button>
              <button class="toolbar-btn excel">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><rect x="1.5" y="1.5" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.1"/><path d="M4 4.5l1.5 2L7 4.5M4 8.5h5M7 6.5h2" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
                Excel
              </button>
            </div>
          </div>

          <!-- Link público -->
          <div class="public-link-box">
            <div class="public-link-label">LINK PÚBLICO PARA CANDIDATOS</div>
            <div class="public-link-row">
              <div class="public-link-url">https://ats.servercontrol-mzt.com/postular/63476703</div>
              <button class="copy-link-btn" id="copyBtn">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M3 11V3a1 1 0 011-1h8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
              </button>
            </div>
          </div>

          <!-- Stats cards -->
          <div class="stats-row">
            <div class="stat-card">
              <div class="stat-icon blue">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="8" cy="7" r="3.5" stroke="currentColor" stroke-width="1.4"/><path d="M2 17c0-3.3 2.7-6 6-6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><circle cx="14" cy="7" r="3.5" stroke="currentColor" stroke-width="1.4" opacity="0.5"/><path d="M14 11c2.2.7 4 2.7 4 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.5"/></svg>
              </div>
              <div class="stat-val">1</div>
              <div class="stat-lbl">Total candidatos</div>
            </div>
            <div class="stat-card">
              <div class="stat-icon emerald">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="#10B981" stroke-width="1.4"/><path d="M6.5 10.5l2.5 2.5 5-5" stroke="#10B981" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div class="stat-val emerald">1</div>
              <div class="stat-lbl">Aptos</div>
            </div>
            <div class="stat-card">
              <div class="stat-icon amber">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="#F59E0B" stroke-width="1.4"/><path d="M10 7v4M10 13v.5" stroke="#F59E0B" stroke-width="1.6" stroke-linecap="round"/></svg>
              </div>
              <div class="stat-val amber">0</div>
              <div class="stat-lbl">A revisar</div>
            </div>
            <div class="stat-card">
              <div class="stat-icon red">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="#EF4444" stroke-width="1.4"/><path d="M7.5 7.5l5 5M12.5 7.5l-5 5" stroke="#EF4444" stroke-width="1.6" stroke-linecap="round"/></svg>
              </div>
              <div class="stat-val red">0</div>
              <div class="stat-lbl">No aptos</div>
            </div>
          </div>

          <!-- Share prompt -->
          <div class="share-prompt">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="#2563EB" stroke-width="1.1"/><path d="M7 4.5v3l1.5 1.5" stroke="#2563EB" stroke-width="1.1" stroke-linecap="round"/></svg>
            <span>Comparte el link en <strong>WhatsApp, LinkedIn, Instagram</strong> o email para recibir más candidatos. La IA los analiza automáticamente.</span>
          </div>
        </div>

        <!-- ─── TAB 3: Candidatos con desglose ─── -->
        <div class="tab-panel" id="tab-candidatos">
          <div class="tab-header compact">
            <div>
              <div class="breadcrumb">Vacantes › <strong>Desarrollador Full Stack Jr. (Node.js / React)</strong></div>
              <div class="vacancy-title-row">
                <h3 class="tab-title">Desarrollador Full Stack Jr. (Node.js / React)</h3>
                <span class="badge-abierta">Abierta</span>
                <span class="badge-area">Tecnología</span>
              </div>
              <p class="vacancy-meta">Nocompila · Desde 25 may 2026 · Hasta 29 jun 2026</p>
            </div>
          </div>

          <!-- Filters -->
          <div class="candidates-toolbar">
            <div class="filter-select">
              <span>Recomendación</span>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5l3 3 3-3" stroke="#94A3B8" stroke-width="1.2" stroke-linecap="round"/></svg>
            </div>
            <div class="sort-select-wrap">
              <span class="sort-label">Ordenar por</span>
              <div class="sort-select">
                <span>Score (desc)</span>
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5l3 3 3-3" stroke="#94A3B8" stroke-width="1.2" stroke-linecap="round"/></svg>
              </div>
            </div>
          </div>

          <!-- Table -->
          <div class="candidates-table">
            <div class="ct-head">
              <span class="col-expand"></span>
              <span class="col-num">#</span>
              <span class="col-candidato">CANDIDATO</span>
              <span class="col-tel">TELÉFONO</span>
              <span class="col-email">EMAIL</span>
              <span class="col-score">SCORE</span>
              <span class="col-habs">HABILIDADES</span>
              <span class="col-ingles">INGLÉS</span>
              <span class="col-rec">RECOMENDACIÓN</span>
              <span class="col-cv">CV</span>
            </div>

            <!-- Row collapsed -->
            <div class="ct-row" id="candidateRow">
              <button class="expand-btn" id="expandBtn" aria-label="Expandir">
                <svg id="expandIcon" width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <span class="col-num row-num">1</span>
              <span class="col-candidato row-candidato">
                <span class="c-avatar" style="background:#1d4ed8">CA</span>
                <span class="c-name">{candidate.name}</span>
              </span>
              <span class="col-tel row-tel">{candidate.phone}</span>
              <span class="col-email row-email">{candidate.email}</span>
              <span class="col-score row-score">
                <span class="score-badge high">{candidate.score}%</span>
              </span>
              <span class="col-habs row-habs">
                {candidate.skills.slice(0, 3).map(s => (
                  <span class="skill-chip">{s}</span>
                ))}
                <span class="skill-more">+{candidate.skills.length - 3}</span>
              </span>
              <span class="col-ingles row-ingles">
                <span class="ingles-text">El candidato tiene</span>
              </span>
              <span class="col-rec row-rec">
                <span class="rec-badge apto">APTO</span>
              </span>
              <span class="col-cv row-cv">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2v8M5.5 8L8 10.5 10.5 8" stroke="#2563EB" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><path d="M2.5 13h11" stroke="#2563EB" stroke-width="1.4" stroke-linecap="round"/></svg>
              </span>
            </div>

            <!-- Row expanded (detail) -->
            <div class="ct-detail" id="candidateDetail" style="display:none">
              <div class="detail-inner">
                <!-- Resumen ejecutivo -->
                <div class="detail-summary">
                  <div class="detail-section-title">RESUMEN EJECUTIVO</div>
                  <p class="summary-text">{candidate.summary}</p>
                </div>

                <!-- Fortalezas + Áreas de mejora + Habilidades -->
                <div class="detail-cols">
                  <div class="detail-col">
                    <div class="detail-col-title fortalezas">FORTALEZAS</div>
                    <ul class="detail-list">
                      {candidate.strengths.map(s => (
                        <li class="detail-item ok">
                          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" fill="rgba(16,185,129,0.15)" stroke="rgba(16,185,129,0.4)" stroke-width="1"/><path d="M4.5 7l2 2 3.5-3" stroke="#10B981" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                          {s}
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div class="detail-col">
                    <div class="detail-col-title mejora">ÁREAS DE MEJORA</div>
                    <ul class="detail-list">
                      {candidate.improvements.map(s => (
                        <li class="detail-item bad">
                          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" fill="rgba(239,68,68,0.12)" stroke="rgba(239,68,68,0.35)" stroke-width="1"/><path d="M5 5l4 4M9 5l-4 4" stroke="#EF4444" stroke-width="1.3" stroke-linecap="round"/></svg>
                          {s}
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div class="detail-col">
                    <div class="detail-col-title habilidades">HABILIDADES ENCONTRADAS</div>
                    <div class="habs-found">
                      {candidate.skills.map(s => (
                        <span class="hab-found">{s}</span>
                      ))}
                    </div>
                    <div class="detail-col-title faltantes" style="margin-top:12px">FALTANTES</div>
                    <div class="habs-found">
                      {candidate.missing.map(s => (
                        <span class="hab-missing">{s}</span>
                      ))}
                    </div>
                    <div class="detail-col-title score-ats-title" style="margin-top:12px">SCORE ATS</div>
                    <div class="score-ats-badge">{candidate.score} / 100</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  #demo {
    padding: 120px 0;
    position: relative;
  }

  .section-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    margin-bottom: 56px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  .section-desc {
    font-size: 17px;
    color: var(--text-secondary);
    max-width: 480px;
    line-height: 1.7;
  }

  /* Wrapper */
  .demo-wrapper {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
  }

  /* Step indicator */
  .demo-steps {
    display: flex;
    align-items: center;
    padding: 20px 28px;
    border-bottom: 1px solid var(--border);
    background: rgba(255,255,255,0.02);
    gap: 0;
  }

  .step-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 12px;
    border-radius: 10px;
    transition: background 0.2s;
  }

  .step-btn:hover { background: rgba(255,255,255,0.05); }

  .step-num {
    width: 28px; height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    background: rgba(255,255,255,0.07);
    border: 1.5px solid var(--border);
    color: var(--text-muted);
    transition: all 0.25s;
    flex-shrink: 0;
  }

  .step-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.25s;
    white-space: nowrap;
  }

  .step-btn.active .step-num {
    background: var(--blue);
    border-color: var(--blue);
    color: #fff;
    box-shadow: 0 0 0 4px rgba(37,99,235,0.2);
  }

  .step-btn.active .step-label { color: var(--text-primary); font-weight: 600; }

  .step-btn.done .step-num {
    background: var(--emerald);
    border-color: var(--emerald);
    color: #fff;
  }

  .step-btn.done .step-label { color: var(--text-secondary); }

  .step-connector {
    flex: 1;
    height: 1px;
    background: var(--border);
    margin: 0 4px;
    max-width: 60px;
  }

  /* Body */
  .demo-body { min-height: 420px; }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* ── SHARED HEADER ── */
  .tab-header {
    padding: 24px 28px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .tab-header.compact { padding-bottom: 12px; }

  .breadcrumb {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .breadcrumb strong { color: var(--text-secondary); }

  .tab-title {
    font-family: var(--font-display);
    font-size: clamp(17px, 2vw, 22px);
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.025em;
  }

  .tab-subtitle {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .tab-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .action-cancel {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    background: none;
    border: 1px solid var(--border);
    padding: 9px 18px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .action-cancel:hover { background: rgba(255,255,255,0.05); }

  .action-create {
    font-size: 13px;
    padding: 9px 18px;
  }

  /* ── TAB 1: FORM ── */
  .form-sections {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 20px 28px 28px;
  }

  .form-section {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
