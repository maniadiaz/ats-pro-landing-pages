<script>
  // Step navigation
  const stepBtns = document.querySelectorAll<HTMLButtonElement>('.step-btn');
  const panels   = document.querySelectorAll<HTMLElement>('.tab-panel');

  function goToTab(target: string) {
    const idx = ['vacante','link','candidatos'].indexOf(target);
    stepBtns.forEach((btn, i) => {
      btn.classList.remove('active', 'done');
      if (i < idx)       btn.classList.add('done');
      else if (i === idx) btn.classList.add('active');
    });
    panels.forEach(p => p.classList.remove('active'));
    document.getElementById(`tab-${target}`)?.classList.add('active');
  }

  stepBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;
      if (target) goToTab(target);
    });
  });

  // "Crear vacante" button advances to tab 2
  document.getElementById('btnCrearVacante')?.addEventListener('click', () => goToTab('link'));

  // Copy link button
  const copyBtn = document.getElementById('copyBtn');
  copyBtn?.addEventListener('click', () => {
    navigator.clipboard?.writeText('https://ats.servercontrol-mzt.com/postular/63476703').catch(() => {});
    copyBtn.style.color = 'var(--emerald)';
    setTimeout(() => { copyBtn.style.color = ''; }, 2000);
  });

  // Expand/collapse candidate detail
  const expandBtn    = document.getElementById('expandBtn');
  const candidateRow = document.getElementById('candidateRow');
  const detail       = document.getElementById('candidateDetail');

  function toggleDetail() {
    const isOpen = detail?.style.display !== 'none';
    if (detail) detail.style.display = isOpen ? 'none' : 'block';
    expandBtn?.classList.toggle('open', !isOpen);
  }

  expandBtn?.addEventListener('click', (e) => { e.stopPropagation(); toggleDetail(); });
  candidateRow?.addEventListener('click', toggleDetail);
</script>
